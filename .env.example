# Minecraft 1.21.1 连接
MINEINTENT_WORLD_ID=local-paper
MINEINTENT_MC_HOST=127.0.0.1
MINEINTENT_MC_PORT=25565
MINEINTENT_MC_USERNAME=MineIntentBot
MINEINTENT_MC_AUTH=offline
MINEINTENT_PRIMARY_PLAYER=你的游戏名

# 同伴档案、持久数据和只读本地调试接口
MINEINTENT_PROFILE=companion-profile.md
MINEINTENT_DATA_DIR=.mineintent
MINEINTENT_DEBUG_PORT=3211

# agent-service（Python）监听地址；Node 侧决策请求发到这里
MINEINTENT_AGENT_SERVICE_URL=http://127.0.0.1:8765

# 以下两项只被 agent-service/server.py 读取，Node 进程不使用
# OpenAI-compatible Chat Completions 接口；密钥只放本地 .env
MINEINTENT_MODEL_BASE_URL=https://你的服务商/v1
MINEINTENT_MODEL_API_KEY=只放在本地
MINEINTENT_MODEL=你的模型名
MINEINTENT_AGENT_SERVICE_PORT=8765
